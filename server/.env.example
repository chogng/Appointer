# Backend (Express)
PORT=3001
# Comma-separated list of allowed frontend origins
# (dev: 5173, preview: 4173)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
JWT_SECRET=dev-secret-key-change-me

# Serve built frontend from ../dist (production-like single-origin)
SERVE_CLIENT=0

# Database
# mysql (default) | sqlite
DB_TYPE=mysql

# MySQL config (when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=drms
DB_CONNECTION_LIMIT=10
# Optional: create database if missing (requires privileges)
DB_CREATE_DATABASE=0
# Optional: seed demo data (recommended off in production)
DB_SEED_DATA=1
# Optional: retry connecting while DB boots (useful for Docker)
DB_CONNECT_RETRIES=15
DB_CONNECT_RETRY_DELAY_MS=1000

# SQLite config (when DB_TYPE=sqlite)
# Database file path (relative to server/ by default)
DB_PATH=drms.db
